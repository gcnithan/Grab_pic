generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

enum UserRole {
  ADMIN
  ORGANIZER
}

enum PhotoProcessingStatus {
  pending
  processing
  completed
  failed
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(ORGANIZER)
  createdAt    DateTime @default(now())

  events       Event[]  @relation("OrganizerEvents")

  @@map("users")
}

model Event {
  id             String   @id @default(uuid())
  name           String
  description    String?
  organizer_id   String
  
  // Access Credentials
  join_code      String   @unique // The "Room ID"
  event_password String   // The "Room Pass" (Hashed)
  
  created_at     DateTime @default(now())

  organizer      User     @relation("OrganizerEvents", fields: [organizer_id], references: [id], onDelete: Cascade)
  photos         Photo[]
  faces          Face[]

  @@index([organizer_id])
  @@index([join_code])
  @@map("events")
}

model Photo {
  id                String                @id @default(uuid())
  event_id          String
  storage_key       String
  processing_status PhotoProcessingStatus @default(pending)
  uploaded_at       DateTime              @default(now())

  event             Event                 @relation(fields: [event_id], references: [id], onDelete: Cascade)
  faces             Face[]

  @@index([event_id])
  @@map("photos")
}

model Face {
  id         String                 @id @default(uuid())
  photo_id   String
  event_id   String
  embedding  Unsupported("vector(512)")
  created_at DateTime               @default(now())

  photo      Photo                  @relation(fields: [photo_id], references: [id], onDelete: Cascade)
  event      Event                  @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@index([event_id])
  @@map("faces")
}